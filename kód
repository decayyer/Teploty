
using Spectre.Console;
using System.Globalization;

string[] days = new string[DateTime.DaysInMonth(2023, 12)];
for (int i = 1; i < (DateTime.DaysInMonth(2023, 12) + 1); i++)
{
    days[i-1] = i.ToString();
}

var day = AnsiConsole.Prompt(
    new SelectionPrompt<string>()
        .Title("Vyber den v měsíci")
        .PageSize(7)
        .MoreChoicesText("[grey](Pohybuj se šipkami nahoru a dolů pro odkrytí víve měsíců)[/]")
        .AddChoices(days)
);
AnsiConsole.WriteLine($"vybral jsi den číslo: {day}");
if (day == "1")
{
    string denJedna = AnsiConsole.Ask<string>("Zadej teplotu tohoto dne:");
    
}
